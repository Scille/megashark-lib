{
  "name": "megashark-lib",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/typings.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.umd.cjs"
    },
    "./theme": "./dist/theme/index.scss"
  },
  "main": "./dist/main.umd.cjs",
  "module": "./dist/main.js",
  "files": [
    "dist"
  ],
  "types": "./dist/typings.d.ts",
  "scripts": {
    "dev": "vite",
    "web:open": "vite --open",
    "web:release": "npm run lint && vite build",
    "build": "vite build",
    "build:local": "npm link && vite build --watch",
    "lint": "eslint . --max-warnings=0 && vue-tsc --noEmit",
    "lint:fix": "eslint . --max-warnings=0 --fix && vue-tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test:unit": "vitest run",
    "prettier:check": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "peerDependencies": {
    "@ionic/core": "^8.8.1",
    "@ionic/vue": "^8.8.1",
    "luxon": "^3.4.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0"
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.11.0",
    "@vuepic/vue-datepicker": "^12.1.0",
    "date-fns": "^4.1.0",
    "ionicons": "^8.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ionic/vue-router": "^8.7.17",
    "@types/luxon": "^3.3.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "eslint": "^10.2.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vue-scoped-css": "^3.0.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.1.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.99.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.6"
  },
  "description": "The megashark-lib UI component library"
}
